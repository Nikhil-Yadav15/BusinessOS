# 1. DATABASE
DATABASE_URL="postgresql://user:password@localhost:5432/atlas_db"

# 2. SECURITY & ENCRYPTION
JWT_SECRET="generate_a_secure_random_string_here_for_access_tokens"

# 3. AI (LANGGRAPH)
OPENROUTER_API_KEY="sk-or-v1-..."
OPENROUTER_MODEL_NAME="tencent/hy3:free"

# 4. EMAIL & OTP VERIFICATION
# SMTP config for Nodemailer (e.g., Gmail, SendGrid, Amazon SES)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM_EMAIL="Atlas OS <noreply@atlasops.cloud>"

# 5. SMS & NOTIFICATIONS (Optional - Used by Workflow Engine)
# Twilio credentials for sending automated SMS alerts
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_FROM_NUMBER="+1234567890"

# 6. SYSTEM AUTOMATION
# A secret key used by GitHub Actions/EventBridge to securely trigger the Outbox Cron Job
CRON_SECRET="generate_a_secure_cron_secret_here"
PROD_API_URL=
